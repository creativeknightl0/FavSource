<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Favourite Actresses</title>
</head>
<body>
    <div style="display: flex; flex-direction: column; gap: 8px;">
        <div style="display: flex; flex-direction: column; border: 1px solid black; border-radius: 16px; background-color: black; color: white;">
            <img src="<%= particularActress.imgSrc %>" alt="Image" style="border-radius: 16px;">
            <div style="display: flex; flex-direction: column; align-items: center;">
                <p><%= particularActress.name %></p>
                <p><%= particularActress.firstSaw %></p>
            </div>
        </div>
    </div>
</body>
</html>